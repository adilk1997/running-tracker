<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Edit Run</title>
  <link rel="stylesheet" href="/styles.css" />
</head>

<body>
  <div class="page page-narrow">
    <div class="form-card">
      <div class="form-header">
        <h1>Edit Run</h1>
        <p class="subtitle">Update your training session</p>
      </div>

      <form action="/runs/<%= run._id %>?_method=PUT" method="POST" class="run-form">

        <div class="form-group">
          <label for="date">Date</label>
          <input
            type="date"
            id="date"
            name="date"
            value="<%= run.date.toISOString().slice(0,10) %>"
            required
          />
        </div>

        <div class="form-group">
          <label for="distance">Distance (km)</label>
          <input
            type="number"
            id="distance"
            name="distance"
            step="0.01"
            min="0"
            value="<%= run.distance %>"
            required
          />
        </div>

        <div class="form-group">
          <label for="time">Time (minutes)</label>
          <input
            type="number"
            id="time"
            name="time"
            min="1"
            value="<%= run.time %>"
            required
          />
        </div>

        <div class="form-actions">
          <a href="/runs" class="btn btn-secondary">Cancel</a>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>

      </form>
    </div>
  </div>
</body>
</html>